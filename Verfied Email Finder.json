            {
              "content": "You are an information extraction assistant.\n\nTask:\nExtract only SaaS or startup company names mentioned in the article.\n\nRules:\n- Return only SaaS or startup company names.\n- Do not include people, investors, products, or organizations that are not companies.\n- Remove duplicates.\n- Return valid JSON only.\n- Do not include explanations or extra text.\n\nOutput format:\n[\n {\"company_name\":\"Company1\"},\n {\"company_name\":\"Company2\"}\n]"
            },
            {
              "content": "=Extract SaaS or startup company names from this article:\n\n{{$json.source_link}}"
            }
          ]
        },
        "options": {}
      },
