    {
      "parameters": {
        "jsCode": "let roles = [\n\"CEO\",\n\"Founder\",\n\"CTO\",\n\"Head of Engineering\",\n\"VP Engineering\",\n\"Head of Product\",\n\"Chief Product Officer\",\n\"COO\",\n\"Head of Sales\"\n];\n\nlet output = [];\n\nfor (let item of items) {\n\n  let result = item.json.organic?.[0];\n  let website = result?.link || \"\";\n\n  website = website\n    .replace(\"https://\",\"\")\n    .replace(\"http://\",\"\")\n    .replace(\"www.\",\"\")\n    .split(\"/\")[0];\n\n  let company = item.json.searchParameters.q\n    .replace(\" official website\",\"\")\n    .trim();\n\n  // choose only ONE role\n  let role = roles[0]; // CEO\n\n  output.push({\n    json: {\n      company_name: company,\n      company_website: website,\n      role: role\n    }\n  });\n\n}\n\nreturn output;"
      },
