    {
      "parameters": {
        "jsCode": "let text = $json.content || \"\";\n\nlet matches = text.match(/\"company_name\"\\s*:\\s*\"([^\"]+)\"/g) || [];\n\nlet companies = matches.map(m => {\n  let name = m.match(/\"company_name\"\\s*:\\s*\"([^\"]+)\"/)[1];\n  return {\n    json: {\n      company_name: name\n    }\n  };\n});\n\nreturn companies;"
      },
