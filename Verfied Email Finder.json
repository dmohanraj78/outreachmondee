        64
      ],
      "id": "5b9647bd-9bc4-4ad4-bf1a-1310a19cf943",
      "name": "Code in JavaScript3"
    },
    {
      "parameters": {
        "jsCode": "let output = [];\n\nfor (let item of items) {\n\n  let data = item.json.data || {};\n\n  let first = data.first_name || \"\";\n  let last = data.last_name || \"\";\n\n  let name = (first + \" \" + last).trim();\n\n  let role = data.position || \"\";\n  let company = data.company || \"\";\n  let email = data.email || \"\";\n  let linkedin = data.linkedin_url || \"\";\n  let website = data.domain ? \"https://\" + data.domain : \"\";\n\n  output.push({\n    json: {\n      name: name,\n      role: role,\n      company: company,\n      email: email,\n      linkedin: linkedin,\n      company_website: website\n    }\n  });\n\n}\n\nreturn output;"
      },
