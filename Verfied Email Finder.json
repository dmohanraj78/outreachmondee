    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  let fullName = item.json.person_name || \"\";\n  let parts = fullName.trim().split(\" \");\n\n  let first_name = parts[0] || \"\";\n  let last_name = parts.slice(1).join(\" \") || \"\";\n\n  return {\n    json: {\n      ...item.json,\n      first_name,\n      last_name\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
