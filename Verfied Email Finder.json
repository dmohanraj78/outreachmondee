    {
      "parameters": {
        "jsCode": "let output = [];\n\nfor (let item of items) {\n\n  let results = item.json.organic || [];\n\n  for (let r of results) {\n\n    let link = r.link || \"\";\n\n    if (!link.includes(\"linkedin.com/in/\")) continue;\n\n    let title = r.title || \"\";\n\n    let person = title\n      .split(\"|\")[0]\n      .split(\"-\")[0]\n      .trim();\n\n    output.push({\n      json: {\n        company_name: item.json.company_name,\n        company_website: item.json.company_website,\n        role: item.json.role,\n        person_name: person,\n        linkedin: link.split(\"?\")[0]\n      }\n    });\n\n  }\n}\n\nreturn output;"
      },
