    {
      "parameters": {
        "jsCode": "let raw = $json.content || $json.response || $json.data || \"\";\n\nif (!raw) return [];\n\n// 🔧 Clean escaped characters\nraw = raw.replace(/\\\\n/g, \"\")\n         .replace(/\\n/g, \"\")\n         .trim();\n\n// 🔧 Extract JSON array safely\nlet match = raw.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n\nif (!match) return [];\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(match[0]);\n} catch (e) {\n  return [];\n}\n\n// 🔥 Remove duplicates + clean names\nlet seen = new Set();\n\nlet output = [];\n\nfor (let item of parsed) {\n  let name = (item.company_name || \"\").trim();\n\n  if (!name) continue;\n\n  // remove weird entries\n  if (name.length < 2) continue;\n  if (name.toLowerCase().includes(\"the \")) continue;\n\n  if (!seen.has(name.toLowerCase())) {\n    seen.add(name.toLowerCase());\n\n    output.push({\n      json: {\n        company_name: name\n      }\n    });\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
