    {
      "parameters": {
        "jsCode": "let roles = [\n\"Founder\",\n\"Co-Founder\",\n\"CEO\",\n\"Chief Business Officer\",\n\"Head of Client Partnerships\",\n\"Client Partner\",\n\"CTO\",\n\"VP Engineering\",\n\"Head of Product\",\n\"Head of Sales\",\n\"COO\",\n\"Managing Director\"\n];\n\nlet output = [];\n\nfor (let item of items) {\n\n  let result = item.json.organic?.[0];\n  let website = result?.link || \"\";\n\n  website = website\n    .replace(\"https://\",\"\")\n    .replace(\"http://\",\"\")\n    .replace(\"www.\",\"\")\n    .split(\"/\")[0];\n\n  let company = item.json.searchParameters.q\n    .replace(\" official website\",\"\")\n    .trim();\n\n  // For mid-range companies, Founders and C-level roles like CBO are highly reachable.\n  let role = roles[0]; \n\n  output.push({\n    json: {\n      company_name: company,\n      company_website: website,\n      role: role\n    }\n  });\n\n}\n\nreturn output;"
      },
