        "messages": {
          "values": [
            {
              "content": "You are a strict data extraction engine.\n\nYou extract ONLY Indian mid-range startup or SaaS company names from the given text.\n\nRules:\n- Identify companies that are likely mid-range (growing, Series A-C, 50-500 employees).\n- EXCLUDE large MNCs (e.g., Google, Microsoft, TCS, Infosys, Reliance, etc.).\n- EXCLUDE investors, media, news reports, or research firms.\n- Remove duplicates and keep names clean.\n\nOutput must be:\n- Valid JSON only\n- Format: [{\"company_name\":\"Company1\"}, {\"company_name\":\"Company2\"}]"
            },
            {
              "content": "=Analyze the following text and extract Indian mid-range startups/SaaS companies matching the criteria:\n\n{{$json.content}}"
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.ollama",
      "typeVersion": 1,
      "position": [
        1472,
        672
      ],
      "id": "353c6fb3-b0e7-4581-a804-8afe97cf80ca",
      "name": "Message a model",
      "credentials": {
        "ollamaApi": {
          "id": "o1Ev6MnTipEqGOnj",
          "name": "Email Finder"
        }
      }
