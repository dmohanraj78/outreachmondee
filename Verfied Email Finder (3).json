        "jsCode": "let output = [];\n\nfor (let item of items) {\n\n  let results = item.json.organic || [];\n  let query = item.json.searchParameters?.q || \"\";\n\n  // 🔥 Extract company + role from query\n  let cleaned = query.replace(\"site:linkedin.com/in\", \"\").trim();\n\n  let words = cleaned.split(\" \");\n\n  let role = words.pop(); // last word = role (CBO, CEO etc)\n  let company = words.join(\" \").trim();\n\n  for (let r of results) {\n\n    let link = r.link || \"\";\n    if (!link.includes(\"linkedin.com/in/\")) continue;\n\n    let title = r.title || \"\";\n\n    // 🧠 Extract person name\n    let name = title.split(\"|\")[0].split(\"-\")[0].trim();\n\n    // 🧠 Extract role from title if available\n    let extractedRole = \"\";\n\n    if (title.includes(\"|\")) {\n      extractedRole = title.split(\"|\")[1].trim();\n    }\n\n    output.push({\n      json: {\n        company_name: company,              // ✅ cleaned\n        person_name: name,\n        role: extractedRole || role,        // ✅ fallback to query role\n        linkedin: link.split(\"?\")[0]\n      }\n    });\n\n  }\n}\n\nreturn output;"
      },
