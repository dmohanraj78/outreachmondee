    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  let query = (item.json.Query || item.json.query || \"\").toLowerCase().trim();\n  let filter = (item.json.Filter || item.json.filter || \"\").toLowerCase().trim();\n\n  // 🚫 Skip empty queries\n  if (!query) {\n    return { json: { skip: true } };\n  }\n\n  // 🔥 Default filter (Targeting Mid-Range Companies)\n  let defaultFilter = 'india startup \"Series A\" OR \"Series B\" OR \"Series C\" OR \"growth stage\" OR \"fastest growing\" -enterprise -mnc -global -TCS -Infosys -Wipro -Reliance -Accenture';\n\n  // ✅ Combine query + filter\n  let finalQuery = filter \n    ? `${query} ${filter}` \n    : `${query} ${defaultFilter}`;\n\n  // 🇮🇳 Force India if missing\n  if (!finalQuery.includes(\"india\")) {\n    finalQuery += \" india mid-range startup\";\n  }\n\n  // 🚫 Remove generic queries\n  let badWords = [\"global\", \"enterprise\", \"MNC\", \"conglomerate\"];\n  if (badWords.some(word => query.includes(word))) {\n    return { json: { skip: true } };\n  }\n\n  return {\n    json: {\n      ...item.json,\n      final_query: finalQuery,\n      skip: false\n    }\n  };\n});"
      },
