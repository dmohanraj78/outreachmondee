      "parameters": {
        "jsCode": "let results = $json.organic;\n\nlet items = [];\n\nfor (let r of results) {\n\nitems.push({\njson:{\ntitle: r.title,\nsource_link: r.link,\nsnippet: r.snippet,\nsignal: $json.signal\n}\n});\n\n}\n\nreturn items;"
      },
