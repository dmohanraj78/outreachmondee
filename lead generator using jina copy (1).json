      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\n// Case 0: Direct URL for Scraping (Bypasses Search)\nif (body.url || body.link || body.scrape_url) {\n  return [{ \n    json: { \n      url: body.url || body.link || body.scrape_url, \n      is_direct_url: true \n    } \n  }];\n}\n\n// Case 1: Direct Array of Company Objects\nif (Array.isArray(body) && body.length > 0 && body[0].company) {\n  return body.map(item => ({\n    json: { \n      company: item.company, \n      website: item.website || \"N/A\",\n      is_direct: true \n    } \n  }));\n}\n\n// Case 2: Batch queries (supports 'search_queries' or 'queries' keys from Webhook)\nconst queries = body.search_queries || body.queries;\n\nif (Array.isArray(queries)) {\n  return queries.map(q => ({\n    json: { \n      Query: q, \n      Signal: body.search_parameters?.location || \"\", \n      Filter: `${body.search_parameters?.industry || \"\"} ${body.search_parameters?.company_scale || \"\"}`.trim()\n    } \n  }));\n}\n\n// Case 3: Google Sheets / Manual Trigger Support\nreturn [{ json: { \n  Query: body.Query || body[\"Target Industry / Query\"] || body.industry || body.query || body.search_query || \"\", \n  Signal: body.Signal || body.signal || \"\", \n  Filter: body.Filter || body.filter || body.filters || \"\" \n} }];\n"
      },
      "id": "fafab64b-eab0-4651-ae6b-7365856b676e",
