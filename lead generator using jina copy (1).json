      "parameters": {
        "jsCode": "// This node must come IMMEDIATELY AFTER your Query Architect (AI)\nlet raw = ($json.content || \"\").replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n  let data = JSON.parse(raw);\n  \n  // Support both 'search_queries' and 'queries' coming from the AI\n  let queries = data.search_queries || data.queries || (Array.isArray(data) ? data : []);\n  \n  if (queries.length === 0 && raw.length > 5) {\n      queries = [raw]; // Fallback to raw string if it's not a list\n  }\n\n  return queries.map(q => ({ json: { query: q } }));\n} catch (e) {\n  // If parsing fails, use the raw content as a single query\n  return [{ json: { query: $json.content } }];\n}\n"
      },
