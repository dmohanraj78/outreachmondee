      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// This version works with EXACTLY what I see on your screen:\nconst query = $json.searchParameters?.q || \"\";\nconst company = query.replace(\" official website domain\", \"\");\n\n// Look inside the 'organic' results for the domain\nconst link = $json.organic?.[0]?.link || \"\";\n\nconst domain = link\n  .replace(/^https?:\\/\\//, \"\")\n  .replace(/^www\\./, \"\")\n  .split(\"/\")[0]\n  .trim();\n\nreturn { \n  company: company || \"Unknown\", \n  website: domain || \"N/A\", \n  recovered: true \n};\n"
      },
