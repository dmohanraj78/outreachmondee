    {
      "parameters": {
        "jsCode": "// THIS VERSION USES A LOOKUP MAP FOR 100% ACCURACY\nlet allLeads = [];\nconst allIncomingItems = $input.all();\n\n// 1. CREATE THE LOOKUP TABLE from Union Results\nconst unionItems = $(\"Union Results1\").all();\nconst websiteMap = {};\n\nfor (const item of unionItems) {\n  if (item.json.company && item.json.website) {\n    // We store the company name as the \"Key\" and website as the \"Value\"\n    websiteMap[item.json.company] = item.json.website;\n  }\n}\n\n// 2. PROCESS THE LINKEDIN RESULTS\nfor (const item of allIncomingItems) {\n  const results = item.json.organic || [];\n  const searchQuery = item.json.searchParameters?.q || \"\";\n  \n  // Get the exact company name we searched for\n  const companyName = searchQuery.split('\"')[1] || \"Unknown Company\";\n\n  // --- THE SMART MATCH ---\n  // We look up the website in our map using the company name\n  const website = websiteMap[companyName] || \"N/A\";\n  // ------------------------\n\n  for (const r of results) {\n    const title = r.title || \"\";\n    const titleParts = title.split(/[-|]/);\n    let fullName = titleParts[0].trim();\n    let role = titleParts.slice(1).join(\"-\").trim() || \"Founder / Executive\";\n    const names = fullName.split(\" \");\n    \n    allLeads.push({\n      json: {\n        company: companyName,\n        website: website, // PROPERLY MATCHED WEBSITE!\n        full_name: fullName,\n        first_name: names[0] || \"\",\n        last_name: names.slice(1).join(\" \") || \"\",\n        role: role,\n        linkedin: r.link,\n        snippet: r.snippet\n      }\n    });\n  }\n}\n\nreturn allLeads;\n"
      },
