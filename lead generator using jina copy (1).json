    {
      "parameters": {
        "jsCode": "let q = ($json.Query || \"\").trim();\nlet f = ($json.Filter || \"\").trim();\nlet s = ($json.Signal || \"\").trim();\n// Fallback if everything is empty to prevent AI errors\nlet final = `${q} ${s} ${f}`.trim() || \"Trending SaaS companies\";\nreturn { ...$json, final_query: final };"
      },
