    {
      "parameters": {
        "jsCode": "function normalize(text) {\n  return text.toLowerCase().replace(/[^a-z]/g, '');\n}\n\nconst results = [];\n\nfor (const item of items) {\n  const person = item.json;\n  const verifier = item.json.data;\n\n  if (!verifier || verifier.status !== \"valid\" || !verifier.email) continue;\n\n  const email = verifier.email.split(\"@\")[0]; // before @\n  const emailParts = email.split(/[.\\-_]/); // split by ., -, _\n\n  const first = normalize(person.first_name || '');\n  const last = normalize(person.last_name || '');\n  const full = normalize(person.full_name || '');\n\n  const emailJoined = normalize(emailParts.join(''));\n\n  let matchScore = 0;\n\n  // Matching logic\n  if (emailParts.includes(first)) matchScore += 2;\n  if (emailParts.includes(last)) matchScore += 2;\n\n  if (emailJoined.includes(first)) matchScore += 1;\n  if (emailJoined.includes(last)) matchScore += 1;\n\n  if (emailJoined.includes(full)) matchScore += 3;\n\n  // Only accept strong matches\n  if (matchScore >= 3) {\n    results.push({\n      name: person.full_name,\n      company: person.company,\n      role: person.role,\n      linkedin: person.linkedin,\n\n      email: verifier.email,\n      score: matchScore,\n\n      quality: verifier.free_email ? \"LOW\" : \"HIGH\"\n    });\n  }\n}\n\nreturn results.map(r => ({ json: r }));"
      },
