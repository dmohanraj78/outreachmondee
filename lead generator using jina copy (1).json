        "jsCode": "return items.map(item => {\n  const name = item.json.full_name.toLowerCase().replace(/\\s/g, '');\n  const domain = item.json.website.toLowerCase();\n\n  return {\n    json: {\n      ...item.json,\n      match_key: `${name}_${domain}`\n    }\n  };\n});"
      },
