    {
      "parameters": {
        "jsCode": "// 1. Get verified results from the current node\nconst verifiedItems = $input.all();\n\n// 2. Access the original profile list (ensure this node name is correct)\nconst sourceProfiles = $(\"Filter Names (Fixed)1\").all();\n\nconst finalLeads = [];\n\nfor (const item of verifiedItems) {\n  const verifiedEmail = item.json.email.toLowerCase();\n  const [handle, emailDomain] = verifiedEmail.split('@');\n\n  // Find the match by checking all possible connections\n  const personMatch = sourceProfiles.find(profile => {\n    const website = (profile.json.website || \"\").toLowerCase();\n    const firstName = (profile.json.first_name || \"\").toLowerCase();\n    const lastName = (profile.json.last_name || \"\").toLowerCase();\n    const fullName = (profile.json.full_name || \"\").toLowerCase();\n\n    // POSSIBILITY 1: Domain/Subdomain Match\n    // Matches \"salesforce.com\" with \"help.salesforce.com\" or \"stripe.com\" with \"docs.stripe.com\"\n    const domainMatch = website.includes(emailDomain) || emailDomain.includes(website.replace(/^(www\\.|docs\\.|help\\.|app\\.)/, ''));\n\n    // POSSIBILITY 2: Name handle match\n    // Matches \"mbenioff\" if first_name is \"Marc\" or last_name is \"Benioff\"\n    // Also matches \"pcollison\" for Patrick Collison\n    const nameInHandle = handle.includes(firstName) || \n                         handle.includes(lastName) || \n                         (firstName.length > 0 && handle.startsWith(firstName[0]) && handle.includes(lastName));\n\n    return domainMatch && nameInHandle;\n  });\n\n  if (personMatch) {\n    finalLeads.push({\n      json: {\n        name: personMatch.json.full_name,\n        company: personMatch.json.company,\n        website: personMatch.json.website,\n        email: item.json.email,\n        linkedin_url: personMatch.json.linkedin,\n        match_type: \"Success\"\n      }\n    });\n  } else {\n    // POSSIBILITY 3: Fallback (Optional)\n    // If no perfect match, you can still output the email with \"Unknown\" to avoid losing data\n    finalLeads.push({\n      json: {\n        name: \"Manual Review Required\",\n        company: emailDomain.split('.')[0],\n        website: emailDomain,\n        email: item.json.email,\n        linkedin_url: \"N/A\",\n        match_type: \"Review\"\n      }\n    });\n  }\n}\n\nreturn finalLeads;"
      },
