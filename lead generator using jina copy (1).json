      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let text = $json.data && $json.data.content ? $json.data.content : ($json.data || $json.content || \"\");\nif (typeof text !== \"string\") text = JSON.stringify(text);\n\n// 1. Remove Markdown Images: ![alt](url)\ntext = text.replace(/!\\[.*?\\]\\(.*?\\)/g, \"\");\n\n// 2. Remove Markdown Links but KEEP the text: [Click Here](https://...) -> Click Here\ntext = text.replace(/\\[([^\\]]+)\\]\\([^\\)]+\\)/g, \"$1\");\n\n// 3. Remove any residual HTML comments\ntext = text.replace(/<!--[\\s\\S]*?-->/g, \"\");\n\n// 4. Remove massive empty gaps (3+ blank lines become 1)\ntext = text.replace(/\\n\\s*\\n\\s*\\n/g, \"\\n\\n\");\n\n// Return the fully cleaned, full-length content!\nreturn { text: text.trim() };\n"
