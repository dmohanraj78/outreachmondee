    {
      "parameters": {
        "jsCode": "// 🧠 Item-by-Item LinkedIn Parsing (Auto-linked by n8n)\nlet result = $json.organic?.[0] || {};\nlet title = result.title || \"\";\nlet snippet = result.snippet || \"\";\n\n// SYNC: n8n automatically pairs this item with the correct one from the AI node\nlet aiData = $(\"AI Output Parser\").item.json || {};\n\n// 1. Precise Split (Handles \" - \", \" | \", \" – \")\nlet titleParts = title.split(/ [\\-\\|\\–] /);\n\n// 2. Extract Name (Always the first part)\nlet namePart = titleParts[0]?.trim() || \"\";\nlet nameAtoms = namePart.split(\" \");\nlet first_name = nameAtoms[0] || \"\";\nlet last_name = nameAtoms.slice(1).join(\" \") || \"\";\n\n// 3. Extract Company from Title (if available)\nlet rawCompany = aiData.company || \"\";\nlet titleCompany = \"\";\n\nif (titleParts.length > 1) {\n  titleCompany = titleParts[1].replace(/Founder|CEO|Owner|Director|Managing|\\|/gi, \"\").trim();\n  if (titleCompany.toLowerCase() === \"linkedin\") {\n     titleCompany = titleParts[2]?.replace(/LinkedIn/gi, \"\").trim() || \"\";\n  }\n}\n\n// 4. Sanitization & Fallback\nlet finalCompany = (titleCompany.length > 2) ? titleCompany : rawCompany;\n\n// 5. 🧹 Snippet Recovery for Name\nif (last_name.length < 2 && snippet.includes(first_name)) {\n  let snippetMatches = snippet.match(new RegExp(first_name + \"\\\\s+([A-Z][a-z]+)\", \"i\"));\n  if (snippetMatches && snippetMatches[1]) {\n    last_name = snippetMatches[1];\n    namePart = first_name + \" \" + last_name;\n  }\n}\n\n// 6. 🧹 Domain Cleaning\nlet rawDomain = aiData.website || \"\";\nlet cleanDomain = rawDomain\n  .replace(/^https?:\\/\\//, \"\")\n  .replace(/^www\\./, \"\")\n  .split(\"/\")[0]\n  .split(\"?\")[0]\n  .trim();\n\n// 🚫 SKIP Check: Skip this item ONLY if domain is missing (Length check moved to If node)\nif (!cleanDomain || cleanDomain === \"N/A\") return [];\n\nreturn {\n  company: finalCompany,\n  domain: cleanDomain,\n  full_name: namePart,\n  first_name: first_name,\n  last_name: last_name,\n  linkedin: result.link,\n  website: rawDomain\n};"
      },
