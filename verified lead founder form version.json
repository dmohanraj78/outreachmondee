    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gemini-3-flash-preview",
          "mode": "list",
          "cachedResultName": "gemini-3-flash-preview"
        },
        "messages": {
          "values": [
            {
              "content": "=\"You are a high-speed data extraction engine. Your task is to identify and extract ALL companies mentioned in the search results. IMPORTANT: Do not use the name of the website that published the article (e.g., Clutch, Forbes, SaaS Talent) as the company name. Instead, look for the specific companies BEING DISCUSSED or LISTED in the text. For example, if an article from 'SaaS Talent' lists 'Steve Huffman of Reddit', the company name is 'Reddit' and the website is 'reddit.com'. Output valid JSON array only.\""
            },
            {
              "content": "={{ \"Search Results JSON: \" + JSON.stringify($json.organic) + \"\\n\\nTarget Criteria: \" + $(\"Unified Input Logic\").first().json.Query + \"\\n\\nTask: Identify and extract as many UNIQUE company-to-website pairs as possible from these results. Ignore the name of the source website.\\nOutput Requirement: Output ONLY a JSON array: [{\\\"company\\\":\\\"Actual Company Name\\\", \\\"website\\\":\\\"companydomain.com\\\"}]. If a website is missing, use 'N/A'.\" }}"
            }
          ]
        },
        "options": {}
      },
      "id": "548cfec2-05e5-48d3-be73-e07f7200d843",
