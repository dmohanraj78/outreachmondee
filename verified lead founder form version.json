        "messages": {
          "values": [
            {
              "content": "\"You are a strict data extraction engine. Your goal is to identify Indian mid-range companies (50–500 employees, startups in Series A-C) from search results. You must ignore massive corporations (like TCS, Reliance, Google) and very small businesses. You always output valid JSON only.\""
            },
            {
              "content": "=\"Analyze these search results and extract the names of 3-5 INDIAN companies that are MID-RANGE startups (growing, 50-500 employees, Series A/B/C).\n\nSearch Results: {{ $json.organic }}\n\nOutput Requirement: Output ONLY a JSON array in this exact format: [{\"company\":\"Name\", \"website\":\"URL\"}]\""
            }
          ]
        },
        "options": {}
      },
