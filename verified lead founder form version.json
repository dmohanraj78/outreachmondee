      "parameters": {
        "jsCode": "let query = ($json.Query || \"\").trim();\nlet filter = ($json.Filter || \"\").trim();\nlet signal = ($json.Signal || \"\").trim();\nlet defaultFilter = 'india startup \"Series A\" OR \"Series B\" OR \"Series C\" -enterprise -mnc -global';\nlet finalQuery = `${query} ${signal} ${filter || defaultFilter}`;\nreturn { ...$json, final_query: finalQuery };"
      },
