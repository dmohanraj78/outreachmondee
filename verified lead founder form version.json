      "id": "2d04af3b-36ed-4d5f-a533-65a14062db82",
      "name": "Serper LinkedIn Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        10832,
        1472
      ]
    },
    {
      "parameters": {
        "jsCode": "// 1. Get all AI results to sync back the company/website info\nlet aiResults = $(\"AI Output Parser\").all();\n\n// 2. Process EVERY search result from Serper\nreturn $input.all().map((item, index) => {\n  let result = item.json.organic?.[0] || {};\n  let title = result.title || \"\";\n  let snippet = result.snippet || \"\";\n  \n  // SYNC: Get the corresponding company/website from the AI Parser node\n  let originalData = aiResults[index]?.json || {};\n\n  // 3. Clean up name from title\n  let namePart = title.split(\"-\")[0].split(\"|\")[0].split(\"–\")[0].trim();\n  let parts = namePart.split(\" \");\n  let first_name = parts[0] || \"\";\n  let last_name = parts.slice(1).join(\" \") || \"\";\n\n  // 4. 🔍 Snippet Recovery (for initials like \"Madhusudan E.\")\n  if (last_name.length < 2 && snippet.includes(first_name)) {\n    let snippetMatches = snippet.match(new RegExp(first_name + \"\\\\s+([A-Z][a-z]+)\", \"i\"));\n    if (snippetMatches && snippetMatches[1]) {\n      last_name = snippetMatches[1];\n      namePart = first_name + \" \" + last_name;\n    }\n  }\n\n  // 5. 🧹 Strip protocols from domain\n  let rawDomain = originalData.website || originalData.domain || \"\";\n  let cleanDomain = rawDomain\n    .replace(/^https?:\\/\\//, \"\")\n    .replace(/^www\\./, \"\")\n    .split(\"/\")[0];\n\n  // 🚫 SKIP: If last name is STILL missing or too short\n  if (last_name.length < 2) return null;\n\n  return {\n    json: {\n      company: originalData.company,\n      domain: cleanDomain,\n      full_name: namePart,\n      first_name: first_name,\n      last_name: last_name,\n      linkedin: result.link\n    }\n  };\n}).filter(i => i !== null);"
      },
