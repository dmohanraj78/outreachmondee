        "jsCode": "let query = ($json.Query || \"\").trim();\nlet filter = ($json.Filter || \"\").trim();\nlet signal = ($json.Signal || \"\").trim();\n// Construct the query strictly from user input\nlet finalQuery = `${query} ${signal} ${filter}`.trim();\nreturn { ...$json, final_query: finalQuery };"
