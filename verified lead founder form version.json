    {
      "parameters": {
        "jsCode": "// Sync with the 'Extract Name' node to get the Name, Company, and LinkedIn\nlet leads = $(\"Extract Name\").all();\n\n// Use $input.all().map() to process every lead from Hunter.io\nreturn $input.all().map((item, index) => {\n  let email = item.json.data?.email;\n\n  // 🚫 SKIP: If no email was found, we filter this person out\n  if (!email) {\n    return null;\n  }\n\n  // SYNC: Get the matching info from the Extract Name node\n  let leadInfo = leads[index]?.json || {};\n\n  // 3. Return ONLY the specific fields you need\n  return {\n    json: {\n      name: leadInfo.full_name,\n      company: leadInfo.company,\n      website: leadInfo.domain,\n      linkedin: leadInfo.linkedin,\n      email: email\n    }\n  };\n}).filter(i => i !== null); // This removes the empty email leads\n"
      },
