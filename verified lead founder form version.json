    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\n// 1. Extract values strictly from the incoming webhook\nconst query = body[\"Target Industry / Query\"] || body.industry || body.query || \"\";\nconst signal = body.signal || body.Signal || \"\";\nconst filter = body.filter || body.filters || body.Filter || \"\";\n\nreturn [{ \n  json: { \n    Query: query, \n    Signal: signal, \n    Filter: filter \n  } \n}];"
      },
