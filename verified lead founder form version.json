    {
      "parameters": {
        "jsCode": "let raw = $json.content || $json.response || $json.text || \"\";\nraw = raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\ntry { return JSON.parse(raw).map(item => ({ json: item })); } catch (e) { return []; }"
      },
