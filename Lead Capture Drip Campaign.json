    "Set Drip Status": {
      "main": [
        [
          {
            "node": "Update Sheets Row",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveExecutionProgress": true
  }
