    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let text = $json.content;\n\n// remove markdown if AI adds ```json\ntext = text.replace(/```json/g, '').replace(/```/g, '').trim();\n\nlet parsed = {};\n\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  parsed = {\n    intent_signal: \"unknown\",\n    summary: \"Parsing failed\",\n    opportunity: \"N/A\"\n  };\n}\n\nreturn {\n  json: {\n    ...$json,\n    intent_signal: parsed.intent_signal || \"unknown\",\n    summary: parsed.summary || \"Could not analyze snippet\",\n    opportunity: parsed.opportunity || \"Manual review recommended\"\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
