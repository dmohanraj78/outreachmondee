      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let text = $json.content;\n\n// remove markdown if AI adds ```json\ntext = text.replace(/```json/g, '').replace(/```/g, '').trim();\n\nlet parsed = {};\n\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  parsed = {\n    name: \"\",\n    role: \"\",\n    company: \"\",\n    intent_signal: \"unknown\",\n    summary: \"Parsing failed\",\n    opportunity: \"N/A\"\n  };\n}\n\nreturn {\n  json: {\n\n    // ORIGINAL DATA\n    Name: parsed.name || $json.Name,\n    Role: parsed.role || $json.Role,\n    Company: parsed.company || $json.Company,\n    \"Email ID\": $json[\"Email ID\"],\n    Industry: $json.Industry,\n\n    title: $json.title,\n    link: $json.link,\n    snippet: $json.snippet,\n    source: $json.source,\n\n    // AI RESULTS\n    intent_signal: parsed.intent_signal,\n    summary: parsed.summary,\n    opportunity: parsed.opportunity\n  }\n};"
      },
