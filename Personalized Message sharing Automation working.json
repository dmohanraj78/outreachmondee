      "parameters": {
        "jsCode": "let output = [];\n\nfor (const item of items) {\n\n  let text = item.json.content || item.json || \"\";\n\n  // convert object to string if needed\n  if (typeof text !== \"string\") {\n    text = JSON.stringify(text);\n  }\n\n  // remove markdown if present\n  text = text.replace(/```json/g, '').replace(/```/g, '').trim();\n\n  // fix escaped new lines and quotes\n  text = text.replace(/\\\\n/g, \" \").replace(/\\\\\"/g, '\"');\n\n  let parsed = {};\n\n  try {\n    parsed = JSON.parse(text);\n  } catch (err) {\n    parsed = { \n      subject: \"Meeting Request: Miraee Agentic OS\",\n      email_body: \"Hi, I tried to reach out but had an issue generating the personalized message. I'd love to show you how Miraee can simplify your travel and expenses.\"\n    };\n  }\n\n  output.push({\n    json: {\n      ...item.json, // PRESERVE ALL ORIGINAL DATA (including row_number)\n      name: parsed.name || item.json.name || item.json.Name || \"\",\n      subject: parsed.subject || \"\",\n      email_body: parsed.email_body || \"\"\n    }\n  });\n\n}\n\nreturn output;"
      },
