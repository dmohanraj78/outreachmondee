        "messages": {
          "values": [
            {
              "content": "You are a Sales Intelligence Researcher for Miraee (Agentic OS for Travel/Expenses). Your goal is to help find 'Business Signals' that indicate a company is scaling, expanding, or growing its team. This helps identify companies whose travel and expense management complexity is increasing."
            },
            {
              "content": "=Generate ONE 'Precision' 2026-style Google search query to find the most recent social hooks for {{ $json.company }}.\n\nFocus on these specific sources:\n- site:linkedin.com/posts\n- site:twitter.com OR site:x.com\n- site:{{ $json.company.toLowerCase().replace(/ /g, '') }}.com/blog\n\nKeywords: (announcement OR \"hiring\" OR \"launch\" OR \"thrilled to share\")\n\nRules:\n- Be concise. Do NOT clutter with too many OR operators.\n- Format as a valid Google Search string.\n- Return ONLY the query text."
            }
          ]
        },
        "options": {}
      },
