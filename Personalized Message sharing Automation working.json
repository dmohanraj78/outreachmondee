    {
      "parameters": {
        "jsCode": "let output = [];\n\nfor (const item of items) {\n\n  const blocks = item.json.text_blocks || [];\n\n  for (const block of blocks) {\n\n    if (block.snippet) {\n\n      output.push({\n        json: {\n          Name: item.json.name,\n          Role: item.json.role,\n          Company: item.json.company,\n          Email: item.json.email,\n          query: item.json.query,\n\n          snippet: block.snippet,\n          source: \"Google AI Mode\"\n        }\n      });\n\n    }\n\n  }\n\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
