    {
      "parameters": {
        "jsCode": "let output = [];\n\nfor (const item of items) {\n  const blocks = item.json.text_blocks || [];\n  // Consolidated all snippets into one text block for the AI to analyze together\n  let consolidatedContent = blocks.map(b => b.snippet).filter(s => s).join(\"\\n\\n---\\n\\n\");\n\n  output.push({\n    json: {\n      ...item.json, // PRESERVE ALL LEAD DATA\n      consolidated_snippets: consolidatedContent || \"No specific snippets found.\",\n      source: \"Google AI Mode\"\n    }\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
